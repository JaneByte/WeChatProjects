{
  "entryPagePath": "pages/index/index",
  "pages": [
    "pages/index/index",
    "pages/category/category",
    "pages/cart/cart",
    "pages/profile/profile",
    "pages/goods/goods",
    "pages/goodsDetail/goodsDetail",
    "pages/search/search",
    "pages/address-list/address-list",
    "pages/address-edit/address-edit",
    "pages/checkout/checkout",
    "pages/order-list/order-list",
    "pages/order-detail/order-detail",
    "pages/pay-result/pay-result",
    "pages/comment-edit/comment-edit",
    "pages/trace-detail/trace-detail",
    "pages/coupon/coupon",
    "pages/service/service",
    "pages/settings/settings"
  ],
  "window": {
    "navigationBarTitleText": "FreshTime 鲜时刻",
    "navigationBarBackgroundColor": "#8cb818",
    "navigationBarTextStyle": "white",
    "enablePullDownRefresh": true,
    "backgroundTextStyle": "dark",
    "backgroundColor": "#fefbf5"
  },
  "style": "v2",
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "defaultContentBox": true,
      "tagNameStyleIsolation": "legacy",
      "sdkVersionBegin": "3.0.0",
      "sdkVersionEnd": "15.255.255"
    }
  },
  "tabBar": {
    "selectedColor": "#004132",
    "color": "rgba(255, 255, 255, 0.8)",
    "backgroundColor": "#8cb818",
    "borderStyle": "black",
    "list": [
      {
        "text": "首页",
        "pagePath": "pages/index/index",
        "iconPath": "assets/icon/main.png",
        "selectedIconPath": "assets/icon/main.png"
      },
      {
        "text": "分类",
        "pagePath": "pages/category/category",
        "iconPath": "assets/icon/classify.png",
        "selectedIconPath": "assets/icon/classify.png"
      },
      {
        "text": "购物车",
        "pagePath": "pages/cart/cart",
        "iconPath": "assets/icon/shoppingCart.png",
        "selectedIconPath": "assets/icon/shoppingCart.png"
      },
      {
        "text": "我的",
        "pagePath": "pages/profile/profile",
        "iconPath": "assets/icon/my.png",
        "selectedIconPath": "assets/icon/my.png"
      }
    ]
  },
  "networkTimeout": {
    "request": 60000,
    "connectSocket": 60000,
    "uploadFile": 60000,
    "downloadFile": 60000
  },
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于获取当地天气"
    }
  },
  "subPackages": [],
  "requiredPrivateInfos": [
    "getLocation"
  ]
}
