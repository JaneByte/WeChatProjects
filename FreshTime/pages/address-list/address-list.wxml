<view class="page">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="title-group">
      <view class="page-title">收货地址</view>
      <view class="page-sub">管理你的常用收货信息</view>
    </view>
    <view class="add-btn" bindtap="onAdd">
      <text class="add-icon">+</text>
      <text>新增</text>
    </view>
  </view>

  <!-- 骨架屏加载态 -->
  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="skeleton-card shimmer" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <!-- 加载错误态 -->
  <view wx:elif="{{loadError}}" class="state error-state">
    <view class="state-icon">!</view>
    <text class="state-text">地址加载失败，请重试</text>
    <button class="state-btn" size="mini" bindtap="onRetryLoad">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!list.length}}" class="state empty-state">
    <view class="state-icon-box">
      <text class="state-icon">📍</text>
    </view>
    <text class="state-text">还没有收货地址</text>
    <text class="state-hint">点击下方按钮添加新地址</text>
    <button class="state-btn primary-btn" size="mini" bindtap="onAdd">添加地址</button>
  </view>

  <!-- 地址列表 -->
  <view wx:else class="list">
    <view
      class="card"
      wx:for="{{list}}"
      wx:key="id"
      data-index="{{index}}"
      bindtap="onChoose"
    >
      <!-- 收件人信息行 -->
      <view class="card-header">
        <view class="user-info">
          <text class="name">{{item.receiverName}}</text>
          <text class="phone">{{item.receiverPhone}}</text>
        </view>
        <view wx:if="{{item.isDefault === 1}}" class="default-tag">默认</view>
      </view>

      <!-- 详细地址 -->
      <view class="address-detail">
        {{item.province}}{{item.city}}{{item.district}}{{item.detail}}
      </view>

      <!-- 操作按钮 -->
      <view class="card-actions">
        <view class="action-btn edit-btn" data-id="{{item.id}}" catchtap="onEdit">
          <text class="action-icon">✎</text>
          <text>编辑</text>
        </view>
        <view class="action-btn delete-btn" data-id="{{item.id}}" catchtap="onDelete">
          <text class="action-icon">✕</text>
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>
</view>