<view class="classify-container">
  <view class="search-section">
    <view class="search-box" bindtap="goToSearch" hover-class="press-effect" aria-label="搜索商品">
      <image class="search-icon" src="/assets/icon/search.png" mode="aspectFit"></image>
      <text class="search-text">搜索{{currentTab === 'fruit' ? '水果' : '蔬菜'}}</text>
    </view>
  </view>

  <view class="main-content">
    <view class="left-panel">
      <view class="capsule-tab">
        <view class="tab-capsule {{currentTab === 'fruit' ? 'active' : ''}}" bindtap="switchTab" data-tab="fruit" hover-class="press-effect">
          <text class="capsule-text">水果</text>
        </view>
        <view class="tab-capsule {{currentTab === 'vegetable' ? 'active' : ''}}" bindtap="switchTab" data-tab="vegetable" hover-class="press-effect">
          <text class="capsule-text">蔬菜</text>
        </view>
      </view>

      <scroll-view class="category-nav" scroll-y enhanced show-scrollbar="{{false}}" scroll-with-animation>
        <view class="nav-item {{currentCategoryId === item.id ? 'active' : ''}}" wx:for="{{categoryList}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}" hover-class="press-effect">
          <view class="nav-indicator"></view>
          <text class="nav-text">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>

    <scroll-view class="right-panel" scroll-y enhanced show-scrollbar="{{false}}" scroll-with-animation>
      <view class="section-header">
        <text class="section-title">{{currentCategory.name}}</text>
        <text class="goods-count" wx:if="{{filteredGoodsList.length > 0}}">{{filteredGoodsList.length}}款</text>
      </view>

      <view class="filter-row">
        <input class="filter-input" placeholder="筛选商品" value="{{filterKeyword}}" bindinput="onFilterInput" />
        <view class="filter-switch {{onlyInStock ? 'active' : ''}}" bindtap="onToggleStock">仅看有货</view>
        <view class="filter-clear" bindtap="onClearFilter">重置</view>
      </view>

      <view class="goods-list">
        <view class="goods-card" wx:for="{{filteredGoodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" hover-class="card-press">
          <view class="card-image-wrapper">
            <image class="card-image" src="{{item.image}}" mode="aspectFill" lazy-load></image>
          </view>
          <view class="card-info">
            <view class="info-header">
              <text class="goods-name">{{item.name}}</text>
              <text class="goods-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
            </view>
            <view class="info-footer">
              <view class="price-box">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.price}}</text>
                <text class="price-unit" wx:if="{{item.unit}}">/{{item.unit}}</text>
              </view>
              <view class="add-cart-btn" catchtap="addToCart" data-id="{{item.id}}" hover-class="press-effect">
                <text class="add-text">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state state-block" wx:if="{{loadError && !loading}}">
        <text class="empty-text state-text">加载失败，请重试</text>
        <view class="retry-btn press-effect" bindtap="onRetryLoad">点击重试</view>
      </view>

      <view class="empty-state state-block" wx:elif="{{filteredGoodsList.length === 0 && !loading}}">
        <text class="empty-text state-text">暂无符合条件的商品</text>
      </view>

      <view class="loading-state state-block state-loading" wx:if="{{loading}}">
        <text class="loading-text state-text">加载中...</text>
      </view>

      <view class="safe-bottom"></view>
    </scroll-view>
  </view>
</view>
