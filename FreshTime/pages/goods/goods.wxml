<view class="page">
  <view class="state" wx:if="{{loading}}">加载中...</view>
  <view class="state" wx:elif="{{list.length === 0}}">暂无商品</view>
  <view class="list" wx:else>
    <view class="item" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="onTapItem">
      <image class="img" src="{{item.mainImage}}" mode="aspectFill"></image>
      <view class="meta">
        <text class="name">{{item.name}}</text>
        <text class="price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
</view>
