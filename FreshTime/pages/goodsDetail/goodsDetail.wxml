<view class='page'>
  <view wx:if='{{loading}}' class='state'>加载中...</view>
  <view wx:elif='{{!detail}}' class='state'>商品不存在</view>

  <view wx:else>
    <image class='cover' src='{{detail.mainImage}}' mode='aspectFill'></image>
    <view class='card'>
      <view class='title'>{{detail.name}}</view>
      <view class='price'>¥{{detail.price}}</view>
      <view class='meta'>库存：{{detail.stock}} {{detail.unit || '件'}}</view>
      <view class='meta'>销量：{{detail.salesVolume || 0}}</view>
      <view class='meta' wx:if='{{detail.stock <= 0}}'>当前状态：已售罄</view>
    </view>

    <view class='actions'>
      <view class='qty-wrap'>
        <view class='qty-btn' bindtap='onMinus'>-</view>
        <input class='qty' type='number' value='{{quantity}}' bindinput='onInputQuantity' />
        <view class='qty-btn' bindtap='onPlus'>+</view>
      </view>
      <button class='btn ghost' bindtap='onAddCart' disabled='{{detail.stock <= 0}}'>加入购物车</button>
      <button class='btn primary' bindtap='onBuyNow' disabled='{{detail.stock <= 0}}'>立即购买</button>
    </view>
    <view class='actions'>
      <button class='btn ghost' bindtap='onGoTrace'>查看溯源信息</button>
    </view>
  </view>
</view>
