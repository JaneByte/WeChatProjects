<view class='page'>
  <view wx:if='{{loading}}' class='state'>加载中...</view>
  <view wx:elif='{{!detail}}' class='state'>订单不存在</view>
  <view wx:else>
    <view class='card'>
      <view class='card-title'>订单信息</view>
      <view class='line'>订单号：{{detail.orderNo}}</view>
      <view class='line'>状态：{{detail.statusText}}</view>
      <view class='line' wx:if='{{detail.status === 0}}'>剩余支付时间：{{countdownText}}</view>
      <view class='line'>下单时间：{{detail.createTime || '-'}}</view>
      <view class='line' wx:if='{{detail.remark}}'>订单备注：{{detail.remark}}</view>
      <view class='actions'>
        <button wx:if='{{detail.status === 0}}' size='mini' class='mini-btn primary' bindtap='onPay'>去支付</button>
        <button wx:if='{{detail.status === 0 || detail.status === 1}}' size='mini' class='mini-btn' bindtap='onCancel'>取消订单</button>
        <button wx:if='{{detail.status === 2}}' size='mini' class='mini-btn' bindtap='onFinish'>确认收货</button>
      </view>
    </view>

    <view class='card'>
      <view class='card-title'>收货信息</view>
      <view class='line'>收货人：{{detail.receiverName}} {{detail.receiverPhone}}</view>
      <view class='line'>收货地址：{{detail.receiverAddress}}</view>
    </view>

    <view class='card'>
      <view class='card-title'>商品清单</view>
      <view class='item' wx:for='{{detail.items}}' wx:key='id'>
        <view class='item-top'>
          <text class='item-name'>{{item.goodsName}}</text>
          <text class='item-total'>¥{{item.totalPrice || (item.price * item.quantity)}}</text>
        </view>
      <view class='item-sub'>
        <text>单价：¥{{item.price}}</text>
        <text>数量：x{{item.quantity}}</text>
      </view>
      <view class='item-sub' wx:if='{{detail.status === 3}}'>
        <button
          size='mini'
          class='mini-btn'
          data-goods-id='{{item.goodsId}}'
          data-goods-name='{{item.goodsName}}'
          bindtap='onGoComment'
        >去评价</button>
      </view>
    </view>
  </view>

    <view class='card'>
      <view class='sum-line'>
        <text>商品件数</text>
        <text>{{goodsCount}} 件</text>
      </view>
      <view class='sum-line'>
        <text>商品总额</text>
        <text>¥{{goodsAmount}}</text>
      </view>
      <view class='sum-line total'>
        <text>实付金额</text>
        <text>¥{{detail.actualAmount}}</text>
      </view>
    </view>
  </view>
</view>
