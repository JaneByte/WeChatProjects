<view class='page'>
  <scroll-view class='tabs' scroll-x>
    <view class='tab {{status === item.value ? "active" : ""}}' wx:for='{{tabs}}' wx:key='value' data-status='{{item.value}}' bindtap='onChangeTab'>
      {{item.label}}
    </view>
  </scroll-view>

  <view wx:if='{{loading}}' class='skeleton-list'>
    <view class='skeleton-card shimmer' wx:for='{{[1,2,3]}}' wx:key='*this'></view>
  </view>
  <view wx:elif='{{loadError}}' class='state'>
    <text>加载失败，请重试</text>
    <button size='mini' bindtap='onRetryLoad'>重试</button>
  </view>
  <view wx:elif='{{!list.length}}' class='state'>暂无订单记录</view>
  <view wx:else class='list'>
    <view class='card' wx:for='{{list}}' wx:key='id' data-id='{{item.id}}' bindtap='onTapItem'>
      <view class='line'>订单号：{{item.orderNo}}</view>
      <view class='line'>状态：{{item.statusText}}</view>
      <view class='line'>金额：¥{{item.actualAmount}}</view>
      <view class='line danger' wx:if='{{item.status === 0}}'>剩余支付时间：{{item.countdownText}}</view>
      <view class='actions'>
        <button size='mini' class='mini-btn' data-id='{{item.id}}' catchtap='onTapItem'>查看详情</button>
        <button wx:if='{{item.status === 0}}' size='mini' class='mini-btn primary' data-id='{{item.id}}' catchtap='onPay'>去支付</button>
        <button wx:if='{{item.status === 0 || item.status === 1}}' size='mini' class='mini-btn' data-id='{{item.id}}' catchtap='onCancel'>取消订单</button>
        <button wx:if='{{item.status === 2}}' size='mini' class='mini-btn' data-id='{{item.id}}' catchtap='onFinish'>确认收货</button>
      </view>
    </view>
  </view>
</view>
