<!-- pages/profile/profile.wxml -->
<view class="profile-page">
  <view class="profile-hero">
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view class="user-meta">
        <text class="nickname">{{userInfo.nickname}}</text>
        <text class="level">{{userInfo.level}}</text>
      </view>
    </view>
  </view>

  <view class="order-card">
    <view class="card-head">
      <text class="card-title">我的订单</text>
      <view class="id-actions">
        <text class="card-link" bindtap="onSwitchUserId">切换用户ID</text>
        <text class="card-link card-link--danger" bindtap="onClearUserId">清除</text>
      </view>
    </view>
    <view class="user-id-row">
      <text class="user-id-text">当前用户ID：{{currentUserIdText}}</text>
    </view>
    <view class="order-grid">
      <view
        class="order-item {{activeOrderTab === item.key ? 'order-item--active' : ''}}"
        wx:for="{{orderTabs}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onOrderTap"
      >
        <text class="order-mark">{{item.mark}}</text>
        <text class="order-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="order-card" wx:if="{{orderList.length > 0}}">
    <view class="card-head">
      <text class="card-title">最近订单</text>
      <text class="card-link">最多显示50条</text>
    </view>
    <view class="recent-order" wx:for="{{orderList}}" wx:key="id">
      <view class="recent-top">
        <text class="recent-no">#{{item.orderNo}}</text>
        <text class="recent-status">{{item.statusText}}</text>
      </view>
      <view class="recent-mid">
        <text class="recent-amount">实付 ¥{{item.actualAmount}}</text>
        <text class="recent-count">{{item.items.length}}件商品</text>
      </view>
      <view class="recent-actions">
        <button
          wx:if="{{item.status === 0}}"
          class="action-btn action-btn--primary"
          size="mini"
          disabled="{{submittingOrderAction}}"
          data-id="{{item.id}}"
          bindtap="onPayOrder"
        >去支付</button>
        <button
          wx:if="{{item.status === 1}}"
          class="action-btn"
          size="mini"
          disabled="{{submittingOrderAction}}"
          data-id="{{item.id}}"
          bindtap="onDeliverOrder"
        >模拟发货</button>
        <button
          wx:if="{{item.status === 2}}"
          class="action-btn"
          size="mini"
          disabled="{{submittingOrderAction}}"
          data-id="{{item.id}}"
          bindtap="onFinishOrder"
        >确认收货</button>
      </view>
    </view>
  </view>

  <view class="order-card empty-order-card" wx:else>
    <text class="empty-order-text">暂无订单</text>
  </view>

  <view class="menu-card">
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onMenuTap"
    >
      <view class="menu-main">
        <text class="menu-title">{{item.label}}</text>
        <text class="menu-desc">{{item.desc}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
