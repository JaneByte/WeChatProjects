<view class='page'>
  <view class='search-bar'>
    <view class='input-wrap'>
      <input
        placeholder='搜索商品名称'
        value='{{keyword}}'
        bindinput='onInput'
        confirm-type='search'
        bindconfirm='onSearch'
      />
      <text wx:if='{{keyword}}' class='clear-input' bindtap='onClearKeyword'>清空</text>
    </view>
    <button size='mini' bindtap='onSearch'>搜索</button>
  </view>

  <view class='history' wx:if='{{history.length > 0 && !searched}}'>
    <view class='history-head'>
      <text class='history-title'>历史搜索</text>
      <text class='history-clear' bindtap='onClearHistory'>清空</text>
    </view>
    <view class='history-tags'>
      <text class='tag' wx:for='{{history}}' wx:key='*this' data-keyword='{{item}}' bindtap='onTapHistory'>{{item}}</text>
    </view>
  </view>

  <view wx:if='{{loading}}' class='state'>搜索中...</view>
  <view wx:elif='{{loadError}}' class='state'>
    <text>加载失败，请重试</text>
    <button size='mini' bindtap='onRetrySearch'>重试</button>
  </view>
  <view wx:elif='{{searched && !list.length}}' class='state'>暂无搜索结果</view>

  <view wx:else class='list'>
    <view class='item' wx:for='{{list}}' wx:key='id' bindtap='onTapItem' data-id='{{item.id}}'>
      <image class='img' src='{{item.mainImage}}' mode='aspectFill'></image>
      <view class='name'>{{item.name}}</view>
      <view class='price'>¥{{item.price}}</view>
    </view>
  </view>
</view>
